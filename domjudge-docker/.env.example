# IMPORTANTE: usar SOLO hex (openssl rand -hex 32). NO usar base64 ni caracteres +/=@#
# Esos caracteres rompen la URL de conexión de Doctrine/DOMjudge.
MYSQL_ROOT_PASSWORD=cambia-esto-con-openssl-rand-hex-32
MYSQL_PASSWORD=cambia-esto-con-openssl-rand-hex-32
# Obtener JUDGEDAEMON_PASSWORD tras el primer arranque del domserver:
#   docker compose exec domserver cat /opt/domjudge/domserver/etc/restapi.secret
JUDGEDAEMON_PASSWORD=

# Dominio de la plataforma (solo informativo, configúralo en nginx/nginx.conf)
# SITE_DOMAIN=quipucode.lat
